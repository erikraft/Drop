{
  "name": "erikraft-drop",
  "version": "1.12.4",
  "type": "module",
  "description": "File sharing by ErikrafT",
  "main": "server/index.js",
  "scripts": {
    "start": "node server/index.js",
    "start:prod": "node server/index.js --rate-limit --auto-restart",
    "build": "npm install --omit=dev",
    "package:linux": "npm run validate:linux-icon && electron-builder --linux deb --x64",
    "package:windows": "npm run validate:linux-icon && electron-builder --win nsis --x64",
    "package:flatpak": "npm run validate:linux-icon && flatpak-builder --force-clean --repo=dist/flatpak-repo dist/flatpak flatpak/io.github.erikraft.Drop.yml",
    "validate:linux-icon": "node scripts/validate-linux-icon.js"
  },
  "author": {
    "name": "ErikrafT",
    "email": "contact+app@erikraft.com",
    "url": "https://github.com/erikraft"
  },
  "license": "ISC",
  "dependencies": {
    "body-parser": "^2.3.0",
    "dotenv": "^16.6.1",
    "express": "^5.2.1",
    "express-rate-limit": "^7.5.1",
    "http-proxy-middleware": "^3.0.7",
    "multer": "^2.2.0",
    "redis": "^4.6.11",
    "ua-parser-js": "^2.0.5",
    "undici": "^6.27.0",
    "unique-names-generator": "^4.7.1",
    "ws": "^8.18.2"
  },
  "devDependencies": {
    "electron": "^39.8.5",
    "electron-builder": "^26.15.3",
    "nodemon": "^3.1.10"
  },
  "engines": {
    "node": ">=20.18.1"
  },
  "private": true,
  "homepage": "https://drop.erikraft.com/"
}
